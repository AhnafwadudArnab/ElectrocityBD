# Database Configuration
DB_HOST=localhost
DB_NAME=electrocity_db
DB_USER=root
DB_PASSWORD=your_database_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Email Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=noreply@electrocitybd.com
MAIL_FROM_NAME=ElectrocityBD

# Payment Gateway
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_BASE_URL=https://checkout.pay.bka.sh/v1.2.0-beta

NAGAD_MERCHANT_ID=your_nagad_merchant_id
NAGAD_MERCHANT_NUMBER=your_nagad_merchant_number
NAGAD_PUBLIC_KEY=your_nagad_public_key
NAGAD_PRIVATE_KEY=your_nagad_private_key
NAGAD_BASE_URL=https://api.mynagad.com

# Security
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
MAX_IMAGE_WIDTH=2000
MAX_IMAGE_HEIGHT=2000

# Backup
BACKUP_PATH=/backups
BACKUP_RETENTION_DAYS=30
